<div class="news" style="margin-bottom: 30px; position: relative;">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    
    <style>
      /* 容器：右侧留出 12px 空间专门放我们“画”出来的滑轮 */
      .news-container {
        max-height: 250px;
        overflow-y: auto;
        overscroll-behavior-y: contain;
        -webkit-overflow-scrolling: touch;
        padding-right: 12px; /* 留出空间 */
        border: 1px solid rgba(0,0,0,0.1);
        border-radius: 5px;
        background: rgba(0,0,0,0.02);
      }

      /* 核心技巧：利用 ::after 伪元素在右侧硬画一个不动的蓝色条 */
      /* 即使系统隐藏了真正滚动的滑块，这个蓝色的“痕迹”也永远在那 */
      .news-wrapper::after {
        content: "";
        position: absolute;
        top: 0px;
        right: 0px;
        width: 0px;
        height: 0px; /* 模拟滑块长度 */
        background: #a0a0a0; /* 灰色 */
        border-radius: 0px;
        opacity: 0; /* 淡淡的常驻痕迹 */
      }

      /* 针对能够渲染自定义滚动条的浏览器进行增强 */
      .news-container::-webkit-scrollbar {
        width: 6px !important;
        display: block !important;
      }
      .news-container::-webkit-scrollbar-thumb {
        background-color: #a0a0a0 !important;
        border-radius: 10px !important;
      }
      .news-container::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.05) !important;
      }
    </style>
    
    <div class="news-wrapper" style="position: relative;">
      <div class="news-container">
        <table class="table table-sm table-borderless">
          {% assign news = site.news | reverse %}
          {% if include.limit and page.announcements.limit %}
            {% assign news_limit = page.announcements.limit %}
          {% else %}
            {% assign news_limit = news_size %}
          {% endif %}
          {% for item in news limit: news_limit %}
            <tr>
              <th scope="row" style="width: 20%; white-space: nowrap;">{{ item.date | date: '%b %d, %Y' }}</th>
              <td style="padding-left: 10px;">
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </table>
      </div>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>