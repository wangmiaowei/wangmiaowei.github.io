{% capture footer_contents %}
  &copy; {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}.
{% endcapture %}

<footer class="mt-1" role="contentinfo" style="background-color: var(--global-bg-color); border-top: 1px solid var(--global-divider-color); padding: 0.2rem 0 0.2rem;">
  {% if site.newsletter.enabled %}
    {% include newsletter.liquid %}
  {% endif %}

  <div class="container">
    <div class="row align-items-center">
      <!-- Left: Map + Last Updated -->
      <div class="col-md-6 mb-2 mb-md-0 text-center text-md-left">
        <div id="clustrmaps-container" class="clustrmaps-container mx-auto mx-md-0" aria-label="Visitor map" style="max-width: 280px;">
          <a href="https://clustrmaps.com/site/1c9ar" title="ClustrMaps">
            <img src="https://clustrmaps.com/map_v2.png?d=4ap2XfBaT0uEV8k86lhhj7VF3cQQHD5Vy5FOqKf3RZw&cl=ffffff&w=600" alt="Visitor map" style="width: 100%; height: auto;" onerror="this.style.display='none'; this.insertAdjacentHTML('afterend', '<span style=\'font-size: 0.8rem; color: #6c757d;\'>Map blocked by browser</span>');">
          </a>
        </div>
        {% if site.last_updated %}
          <div style="font-size: 0.85rem; color: var(--global-text-color-light); margin-top: 0.3rem; letter-spacing: 0.5px; font-weight: 500;">
            Site last updated: <span style="color: var(--global-theme-color);">{{ 'now' | date: '%Y-%m-%d' }}</span>
          </div>
        {% endif %}
      </div>

      <!-- Right: Icons + Copyright -->
      <div class="col-md-6 text-center text-md-right">
        <div class="contact-icons">
          {% if site.data.socials %}
            {% for item in site.data.socials %}
              <a href="{{ item.link }}" title="{{ item.name }}" target="_blank" rel="noopener noreferrer">
                <i class="{{ item.icon }}" style="line-height: 1;"></i>
              </a>
            {% endfor %}
          {% endif %}
        </div>
        <div style="font-size: 0.85rem; color: var(--global-text-color-light); line-height: 1.6; margin-top: 0.2rem;">
          {{ footer_contents }}
          {% if site.footer_text %}
            <br><span style="font-size: 0.8rem; opacity: 0.85;">{{ site.footer_text }}</span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Mobile-specific footer optimizations */
  @media (max-width: 767.98px) {
    footer {
      padding: 0.8rem 0;
    }
    
    .clustrmaps-container {
      max-width: 240px !important;
      margin-bottom: 0.5rem !important;
    }
    
    .footer-contact-icons {
      margin-bottom: 0.5rem;
    }
    
    .row.align-items-center {
      flex-direction: column;
      text-align: center;
    }
    
    .col-md-6 {
      width: 100%;
      margin-bottom: 1rem;
    }
  }
</style>
